<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <title>HostARM</title>
</head>

  <body>

<div class="grid-container">

  <h1 class="item20">HostARM - Your ARM docs</h1>

  <div class="item21">
    <h2>Configuration</h2>
    <form action="/" method="post">

  <h3>Manual</h3>
  <ul>
    <li class="item21">
      <input type="radio" id="arm2012" name="manual" value="ARM_2012" @_MAN_ARM_2012_@>
      <label for="arm2012">ARM 2012</label><br>
    </li>

    <li class="item21">
      <input type="radio" id="arm2022" name="manual" value="ARM_2022" @_MAN_ARM_2022_@>
      <label for="arm2022">ARM 2022</label><br>
    </li>

    <li class="item21">
      <input type="radio" id="aarm202Y" name="manual" value="AARM_202Y" @_MAN_AARM_202Y_@>
      <label for="aarm202Y">AARM 202Y (Draft 4)</label>
    </li>
  </ul>

  <h3>Pyning</h3>

  <ul>
    <li class="item21">
      <input type="checkbox" id="pyne_banner" name="pyne_banner" value ="true" @_PYNE_BANNER_@>
      <label for="pyne_banner">Pyne banner</label>
    </li>

    <li class="item21">
      <input type="checkbox" id="pyne_nav_top" name="pyne_nav_top" value ="true" @_PYNE_NAV_TOP_@>
      <label for="pyne_nav_top">Pyne top navigation</label>
    </li>

    <li class="item21">
      <input type="checkbox" id="pyne_nav_bottom" name="pyne_nav_bottom" value ="true" @_PYNE_NAV_BOTTOM_@>
      <label for="pyne_nav_bottom">Pyne bottom navigation</label>
    </li>

    <li class="item21">
      <input type="checkbox" id="pyne_sponsor" name="pyne_sponsor" value ="true" @_PYNE_SPONSOR_@>
      <label for="pyne_sponsor">Pyne sponsor</label>
    </li>
  </ul>

  <h3>Modernize</h3>

  <ul>
    <li class="item31">
      <input type="checkbox" id="modernize" name="modernize" value ="true" @_MODERNIZE_@>
      <label for="modernize">Add new navigation bar</label>
    </li>
  </ul>

  <h3>Submit</h3>
  <ul>
    <li class="item41">
      <input type="submit" id="submit" id="submit" value="Submit">
      <label for="submit">By submitting you accept cookies</label>
    </li>
  </ul>

</form>

</div>

  <div class="item23">
    <h2>Navigation Keys</h2>
    <table class="item23">
      <tbody>
	<tr><td style="width: 3em;">B, P</td><td><b>B</b>efore, <b>P</b>revious page</td></tr>
	<tr><td>F, N</td><td><b>F</b>orward, <b>N</b>ext</td></tr>
	<tr><td>C, T</td><td><b>C</b>ontents, <b>T</b>able of contents</td></tr>
	<tr><td>I</td><td><b>I</b>ndex</td></tr>
	<tr><td>R</td><td><b>R</b>eference</td></tr>
	<tr><td>A</td><td><b>A</b>da-Auth search</td></tr>
	<tr><td>S</td><td><b>S</b>earch with Tipuesearch</td></tr>
	<tr><td>H</td><td><b>H</b>ome</td></tr>
      </tbody>
    </table>
  </div>

<div class="item24">
<h2>Feedback</h2>
<p class="item24-p">For <a href="https://github.com/jquorning/hostarm/discussions">questions</a>,
  <a href="https://github.com/jquorning/hostarm/issues">bug
  reports</a>, <a href="https://github.com/jquorning/hostarm/issues">feature
  requests</a>,
  and <a href="https://github.com/jquorning/hostarm/discussions">user
  stories</a>, please visit
  the <a href="https://github.com/jquorning/hostarm">project
  website</a>.</p>
</div>
</div>

</body>
</html>
