<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>readme - HostARM</title>
  <link rel="stylesheet" href="/assets/css/hostarm.css" />
</head>

<body>
<h1>Welcome</h1>

<table>
<tr><td><a href="@_MANUAL_TOC_@">Contents</a></td></tr>
<tr><td><a href="@_MANUAL_INDEX_@">Index</a></td></tr>
<tr><td><a href="search">Search</a></td></tr>
<tr><td><a href="@_MANUAL_AUTH_SEARCH_@">Ada Auth search</a></td></tr>
<tr><td><a href="@_MANUAL_REFERENCE_@">Reference</a></td></tr>
</table>

<h2>HostARM pages</h2>
<table>
  <tr><td><a href="http://localhost:2778/">/</a></td><td>Toplevel</td></tr>
  <tr><td><a href="http://localhost:2778/search">/search</a></td><td>Local search</td></tr>
</table>

<h2>Key Navigation</h2>
<table>
  <tr><td>B, P</td><td>Before, Previous page</td></tr>
  <tr><td>F, N</td><td>Forward, Next page</td></tr>
  <tr><td>C, T</td><td>Contents, Table of contents</td></tr>
  <tr><td>I</td><td>Index page</td></tr>
  <tr><td>R</td><td>Reference page</td></tr>
  <tr><td>A</td><td>Ada-Auth search page</td></tr>
  <tr><td>S</td><td>Search with Tipuesearch</td></tr>
  <tr><td>K</td><td>Toplevel page (<b>H</b>ome)</td></tr>
</table>

<h1>Configuration</h1>

<form action="/" method="post">
<h2>Manual</h2>
  <input type="radio" id="arm2012" name="manual" value="ARM_2012" @_MAN_ARM_2012_@>
  <label for="arm2012">ARM 2012</label><br>

  <input type="radio" id="arm2022" name="manual" value="ARM_2022" @_MAN_ARM_2022_@>
  <label for="arm2022">ARM 2022</label><br>

  <input type="radio" id="aarm202Y" name="manual" value="AARM_202Y" @_MAN_AARM_202Y_@>
  <label for="aarm202Y">AARM 202Y</label>

  <h2>Configuration</h2>

  <h3>Pyning</h3>

  <input type="checkbox" id="strip_title" name="strip_title" value ="true" @_STRIP_TITLE_@>
  <label for="strip_title" id="strip_title">Strip title</label>
  <br>

  <input type="checkbox" id="strip_nav_top" name="strip_nav_top" value ="true" @_STRIP_NAV_TOP_@>
  <label for="strip_nav_top" id="strip_nav_top">Strip top navigation</label>
  <br>

  <input type="checkbox" id="strip_nav_bottom" name="strip_nav_bottom" value ="true" @_STRIP_NAV_BOTTOM_@>
  <label for="strip_nav_bottom" id="strip_nav_bottom">Strip bottom navigation</label>
  <br>

  <input type="checkbox" id="strip_sponsor" name="strip_sponsor" value ="true" @_STRIP_SPONSOR_@>
  <label for="strip_sponsor" id="strip_sponsor">Strip sponsor</label>
  <br>

  <h3>Submit</h3>
  <input type="submit" id="submit" id="submit" value="Submit">
  <label for="submit" id="submit">By pressing submit you accept a cookie</label>
  <br>

</form>

<h2>Invocation</h2>

<code>
hostarm [--port &lt;Port&gt;]</code><br>
<ht>Port - Default is 2778 which is decimal for 16#Ada#.<br>

  <h2>Feedback</h2>
  <p>For <a href="https://github.com/jquorning/hostarm/discussions">questions</a>, <a href="https://github.com/jquorning/hostarm/issues">bug
  reports</a>, <a href="https://github.com/jquorning/hostarm/issues">feature
  requests</a>,
  and <a href="https://github.com/jquorning/hostarm/discussions">user
  stories</a>, please visit
  the <a href="https://github.com/jquorning/hostarm">project
  website</a>.</p>

</body>
</html>
